# ── Supabase (Self-Hosted) ──
# Your Supabase project URL (local or remote)
VITE_SUPABASE_URL=http://localhost:8000
# Supabase anon/public key (find in Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend API Server ──
# URL of your Express/API server that talks to Supabase
VITE_API_URL=http://localhost:3001

# ── Email Notifications (optional) ──
# Self-hosted SMTP or a service like Resend/SendGrid
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=school@saintmarychurch.org

# ── SMS Notifications (optional) ──
# Twilio or self-hosted SMS gateway
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ── Web Push (optional) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:school@saintmarychurch.org

# ── AI Chat (optional) ──
# Anthropic Claude API key for the Orthodox faith Q&A assistant
ANTHROPIC_API_KEY=
